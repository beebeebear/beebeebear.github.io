	srcset=&#34;https://beebeebear.github.io/p/videoeditinggameplayer/20250701__%E5%8D%9A%E5%AE%A2__%E6%8A%80%E6%9C%AF%E5%88%86%E4%BA%AB__%E5%BD%95%E5%88%B6%E5%89%AA%E8%BE%91.OBS.%E9%87%87%E9%9B%86%E6%BA%90__BeeBear_hu9545331179414878409.png 480w, https://beebeebear.github.io/p/videoeditinggameplayer/20250701__%E5%8D%9A%E5%AE%A2__%E6%8A%80%E6%9C%AF%E5%88%86%E4%BA%AB__%E5%BD%95%E5%88%B6%E5%89%AA%E8%BE%91.OBS.%E9%87%87%E9%9B%86%E6%BA%90__BeeBear_hu2142593798278233220.png 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;采集源&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;55&#34;
		data-flex-basis=&#34;133px&#34;
	
&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://beebeebear.github.io/p/videoeditinggameplayer/20250701__%E5%8D%9A%E5%AE%A2__%E6%8A%80%E6%9C%AF%E5%88%86%E4%BA%AB__%E5%BD%95%E5%88%B6%E5%89%AA%E8%BE%91.OBS.%E9%9F%B3%E8%BD%A8__BeeBear.png&#34;
	width=&#34;1671&#34;
	height=&#34;558&#34;
	srcset=&#34;https://beebeebear.github.io/p/videoeditinggameplayer/20250701__%E5%8D%9A%E5%AE%A2__%E6%8A%80%E6%9C%AF%E5%88%86%E4%BA%AB__%E5%BD%95%E5%88%B6%E5%89%AA%E8%BE%91.OBS.%E9%9F%B3%E8%BD%A8__BeeBear_hu15747499497511727510.png 480w, https://beebeebear.github.io/p/videoeditinggameplayer/20250701__%E5%8D%9A%E5%AE%A2__%E6%8A%80%E6%9C%AF%E5%88%86%E4%BA%AB__%E5%BD%95%E5%88%B6%E5%89%AA%E8%BE%91.OBS.%E9%9F%B3%E8%BD%A8__BeeBear_hu13074275810356248213.png 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;音轨&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;299&#34;
		data-flex-basis=&#34;718px&#34;
	
&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://beebeebear.github.io/p/videoeditinggameplayer/20250701__%E5%8D%9A%E5%AE%A2__%E6%8A%80%E6%9C%AF%E5%88%86%E4%BA%AB__%E5%BD%95%E5%88%B6%E5%89%AA%E8%BE%91.OBS.%E8%BE%93%E5%87%BA%E9%9F%B3%E8%BD%A8%E8%AE%BE%E7%BD%AE__BeeBear.png&#34;
	width=&#34;1475&#34;
